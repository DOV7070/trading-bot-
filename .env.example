# === Binance API ===
# Crée tes clés ici : https://www.binance.com/en/my/settings/api-management
# Pour le PAPER TRADING (Testnet) : https://testnet.binance.vision/
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# true = paper trading (testnet) | false = trading reel
USE_TESTNET=true

# === Bot config ===
SYMBOL=BTCUSDT
INTERVAL=15m                # 1m, 5m, 15m, 1h, 4h, 1d
QUANTITY_USDT=20            # Montant en USDT par trade
MAX_OPEN_POSITIONS=1

# === Strategie ===
STRATEGY=rsi_ma             # rsi_ma | ma_cross | macd
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
FAST_MA=20
SLOW_MA=50

# === Risk Management ===
STOP_LOSS_PCT=2.0           # Stop loss en %
TAKE_PROFIT_PCT=4.0         # Take profit en %

# === Loop ===
LOOP_INTERVAL_SECONDS=60    # Frequence de check du marche

# === Flask Dashboard ===
PORT=8080
